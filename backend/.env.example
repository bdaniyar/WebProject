# Backend environment variables
# Copy this file to `.env` and fill values.

# Where your frontend runs (used for links in emails)
SITE_URL=http://localhost:4200

# SMTP settings (example for Gmail/SMTP providers)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=Hotel Booking <your_email@gmail.com>

# For local debugging you can use console backend instead:
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

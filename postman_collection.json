  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"demo1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register",
                ""
              ]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Save tokens if present in response",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json.access) pm.collectionVariables.set('accessToken', json.access);",
                  "  if (json.refresh) pm.collectionVariables.set('refreshToken', json.refresh);",
                  "} catch (e) {}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login",
                ""
              ]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
